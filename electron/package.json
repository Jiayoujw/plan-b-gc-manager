{
  "name": "teyvat-manager-desktop",
  "version": "0.2.0",
  "description": "Teyvat Manager - 桌面应用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.teyvat.manager",
    "productName": "Teyvat Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "../server.js",
      "../services/**/*",
      "../routes/**/*",
      "../public/**/*",
      "../data/**/*",
      "../.env.example",
      "../package.json",
      "../node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../.proxy-ssl",
        "to": ".proxy-ssl"
      }
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "../public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Teyvat Manager"
    }
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  }
}