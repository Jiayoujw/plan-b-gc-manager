# Plan-B 提瓦特管理台 环境配置
# 复制此文件为 .env.local 进行本地覆盖

# --- 服务端口 ---
WEB_PORT=8080
PROXY_PORT=8081
GC_DISPATCH_PORT=443
GC_GAME_PORT=22102
MONGO_PORT=27017

# --- Grasscutter 路径 ---
# Grasscutter 安装目录
GC_DIR=%USERPROFILE%/AppData/Roaming/cultivation/grasscutter
# MongoDB 可执行文件路径（为空则使用 PATH 中的 mongod）
MONGOD_BIN=C:/Program Files/MongoDB/Server/8.3/bin/mongod.exe
# MongoDB 数据目录
MONGO_DATA_DIR=%USERPROFILE%/mongo-data
MONGO_LOG_DIR=%USERPROFILE%/mongo-log

# --- 安全 ---
# JWT 签名密钥（生产环境请修改为随机字符串）
JWT_SECRET=teyvat-manager-secret-key-2024
# JWT 过期时间
JWT_EXPIRY=24h

# --- 代理 ---
# 代理自动恢复开关
PROXY_AUTO_RECOVER=true
# 心跳检测间隔（毫秒）
PROXY_HEARTBEAT_MS=10000
# CA 证书有效期（天）
CA_CERT_VALIDITY_DAYS=365

# --- 审计 ---
# 审计日志最大保留条数
AUDIT_MAX_RECORDS=1000
# 审计日志保留天数
AUDIT_RETENTION_DAYS=30

# --- 备份 ---
# 自动备份间隔（小时）
BACKUP_INTERVAL_HOURS=6
# 备份目录
BACKUP_DIR=%USERPROFILE%/AppData/Roaming/cultivation/grasscutter/backups

# --- 联机 ---
# KCP 更新间隔（毫秒，越低延迟越低但 CPU 消耗越高）
KCP_INTERVAL_MS=10
# 实体加载范围
ENTITY_LOAD_RANGE=150
# 场景实体上限
SCENE_ENTITY_LIMIT=5000

# --- 性能 ---
# 最大并发连接数
MAX_CONNECTIONS=50
# API 限流（请求/分钟）
API_RATE_LIMIT=200
# 登录限流（次数/15分钟）
LOGIN_RATE_LIMIT=20

# --- 日志 ---
LOG_LEVEL=info
